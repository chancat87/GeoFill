{
  "manifest_version": 3,
  "name": "GeoFill - 智能注册助手",
  "version": "1.8.0",
  "description": "根据地理位置智能生成注册信息并一键填写表单",
  "browser_specific_settings": {
    "gecko": {
      "id": "geofill@example.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "menus",
    "permissions"
  ],
  "host_permissions": [
    "https://ipapi.co/*",
    "https://ipwho.is/*",
    "https://api.mail.tm/*",
    "https://*.mail.tm/*"
  ],
  "optional_host_permissions": [
    "https://api.geoapify.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://api.openai.com/*"
  ],
  "commands": {
    "fill-form": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "填写表单"
    }
  }
}
